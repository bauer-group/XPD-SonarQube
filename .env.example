# =============================================================================
# SonarQube — BAUER GROUP Self-Hosted Stack — Environment Template
# =============================================================================
# Copy to `.env` and fill in the CHANGE_ME_* values, or generate one with:
#
#     python scripts/generate-env.py
#
# The generator fills POSTGRES_PASSWORD with a random hex secret. Everything
# else has a working default or is an operator-supplied integration value.
#
# Variable expansion: `${VAR}` references below are resolved by Docker Compose
# from THIS file when rendering the compose `environment:` blocks. Values are
# NOT expanded within this file itself — keep literal values literal.
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================
# STACK_NAME prefixes every container, volume and the internal network so
# multiple stacks can coexist on one host (e.g. sonarqube_APP, sonarqube-postgres).
STACK_NAME=sonarqube

# IANA timezone for all containers (log timestamps, scheduler, DB).
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Configuration
# =============================================================================
# All tags are FLOATING so the stack auto-updates to current, patched software.
# CI rebuilds the wrapper images and the daily base-image monitor catches digest
# drift — there are no SonarQube/plugin version numbers to maintain by hand.
# (The wrapper auto-resolves the newest plugin-compatible SonarQube at build
# time — see docs/branch-analysis.md and docs/upgrade.md.)

# --- Wrapper image (Community Build + branch plugin) --------------------------
SONARQUBE_IMAGE=ghcr.io/bauer-group/XPD-SonarQube/sonarqube
SONARQUBE_VERSION=latest

# --- PostgreSQL 18 ------------------------------------------------------------
# Plain postgres 18 (NO pgvector — that vector extension is an Outline-only
# need). SonarQube supports PostgreSQL 14–18. Major-pinned + patch-floating:
# a DB MAJOR upgrade is intentional/manual.
POSTGRES_IMAGE=postgres
POSTGRES_VERSION=18-alpine

# --- Kernel init sidecar (sets vm.max_map_count / fs.file-max for Elasticsearch)
SONARQUBE_INIT_IMAGE=busybox
SONARQUBE_INIT_VERSION=stable

# --- Backup sidecar -----------------------------------------------------------
SONARQUBE_BACKUP_IMAGE=ghcr.io/bauer-group/XPD-SonarQube/sonarqube-backup
SONARQUBE_BACKUP_VERSION=latest


# =============================================================================
# Hostnames & Reverse Proxy (traefik / coolify variants only)
# =============================================================================
# Public FQDN. A DNS A/AAAA record must point at the reverse-proxy host BEFORE
# first start (Let's Encrypt HTTP-01 challenge needs it reachable).
SONARQUBE_HOSTNAME=sonarqube.development.app.bauer-group.com

# External Docker network your Traefik instance is attached to.
PROXY_NETWORK=EDGEPROXY


# =============================================================================
# SonarQube Application
# =============================================================================
# Host port for the development variant only (traefik/coolify expose via proxy).
SONARQUBE_PORT=9000

# Server base URL — used to build correct links in notifications and PR
# decoration. Leave EMPTY to use each compose variant's sensible default:
#   development → http://localhost:${SONARQUBE_PORT}
#   traefik / coolify → https://${SONARQUBE_HOSTNAME}
# Set it explicitly only to override (e.g. a custom domain or sub-path).
SONARQUBE_SERVER_BASE_URL=

# --- JVM heap sizing ----------------------------------------------------------
# SonarQube runs THREE JVMs (web, compute-engine, Elasticsearch search). Set
# ONLY heap opts here — the branch-plugin -javaagent options are baked into the
# wrapper image (do not add them here).
#
# These heaps share the host with PostgreSQL (sized separately below), the
# Elasticsearch off-heap memory and the OS page cache — so "host RAM" is the
# WHOLE box, not a per-JVM budget. Pick one column and copy all three values
# verbatim into the lines below. The 4 GB column is the stock SonarQube default.
#
#   ┌───────────────────────┬───────────────────┬─────────────────┬─────────────────┐
#   │ Host RAM (whole box)  │ 4 GB (default)    │ 8 GB            │ 16 GB           │
#   ├───────────────────────┼───────────────────┼─────────────────┼─────────────────┤
#   │ SONAR_WEB_JAVAOPTS    │ -Xmx512m -Xms128m │ -Xmx1g -Xms128m │ -Xmx2g -Xms128m │
#   │ SONAR_CE_JAVAOPTS     │ -Xmx512m -Xms128m │ -Xmx1g -Xms128m │ -Xmx2g -Xms128m │
#   │ SONAR_SEARCH_JAVAOPTS │ -Xmx512m -Xms512m │ -Xmx1g -Xms1g   │ -Xmx2g -Xms2g   │
#   │ + MaxDirectMemorySize │ 256m              │ 512m            │ 1g              │
#   └───────────────────────┴───────────────────┴─────────────────┴─────────────────┘
#
# Why the -Xms values differ between the three JVMs:
#   * web / CE → bump only -Xmx; the small -Xms128m initial heap is fine, the
#                JVM grows it lazily under load.
#   * search   → Elasticsearch wants -Xms == -Xmx (avoids heap-resize GC pauses)
#                plus -XX:MaxDirectMemorySize at ~half the heap (Lucene buffers).
SONAR_WEB_JAVAOPTS=-Xmx512m -Xms128m
SONAR_CE_JAVAOPTS=-Xmx512m -Xms128m
SONAR_SEARCH_JAVAOPTS=-Xmx512m -Xms512m -XX:MaxDirectMemorySize=256m

# --- SSO / Authentication -----------------------------------------------------
# Full setup: docs/authentication.md. Auth providers are configured in the
# SonarQube UI (Administration → Authentication) — no runtime env vars here.
#   * Entra ID (SAML 2.0): native, no plugin needed.
#   * Zitadel (generic OIDC): the sonar-auth-oidc plugin ships in the wrapper
#     image by default (verified on SonarQube 26.5). To omit it, build with
#     --build-arg INCLUDE_OIDC_PLUGIN=false ./src/sonarqube


# =============================================================================
# PostgreSQL (SonarQube database)
# =============================================================================
POSTGRES_USER=sonar
POSTGRES_DB=sonar
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# --- Performance tuning (baseline: 4 GB host, SSD/NVMe) -----------------------
#   ┌──────────────────────────┬──────────┬──────────┬──────────┐
#   │ Setting                   │ 4 GB     │ 8 GB     │ 16 GB    │
#   ├──────────────────────────┼──────────┼──────────┼──────────┤
#   │ PG_SHARED_BUFFERS         │ 512MB    │ 2GB      │ 4GB      │
#   │ PG_EFFECTIVE_CACHE_SIZE   │ 1536MB   │ 6GB      │ 12GB     │
#   │ PG_WORK_MEM               │ 8MB      │ 16MB     │ 32MB     │
#   │ PG_MAINTENANCE_WORK_MEM   │ 128MB    │ 256MB    │ 512MB    │
#   │ PG_MAX_WAL_SIZE           │ 1GB      │ 2GB      │ 4GB      │
#   │ PG_MIN_WAL_SIZE           │ 256MB    │ 512MB    │ 1GB      │
#   │ PG_MAX_CONNECTIONS        │ 100      │ 150      │ 200      │
#   └──────────────────────────┴──────────┴──────────┴──────────┘
PG_MAX_CONNECTIONS=100
PG_SHARED_BUFFERS=512MB
PG_WORK_MEM=8MB
PG_EFFECTIVE_CACHE_SIZE=1536MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_MAX_WAL_SIZE=1GB
PG_MIN_WAL_SIZE=256MB
PG_RANDOM_PAGE_COST=1.1
PG_EFFECTIVE_IO_CONCURRENCY=200


# =============================================================================
# SMTP
# =============================================================================
# Used by the BACKUP sidecar for e-mail alerts (reliable, env-driven).
#
# NOTE: SonarQube's OWN notification e-mails are configured in the web UI under
# Administration → Configuration → General → Email (stored in the database), not
# via these variables. See docs/installation.md.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_SECURE=starttls


# =============================================================================
# Backup Sidecar (compose profile: backup — OFF by default)
# =============================================================================
# The sidecar is gated behind the "backup" compose profile, so a plain
# `docker compose up` does NOT start it. Two ways to turn it on:
#
#   * Persistent (recommended): set COMPOSE_PROFILES=backup below — Docker
#     Compose reads it straight from .env, so the sidecar comes up on every
#     `docker compose up -d` with no extra CLI flag to remember.
#   * One-off / on-demand: pass --profile backup on the command line, e.g.
#       docker compose -f docker-compose.traefik.yml --profile backup up -d
#       docker compose -f docker-compose.traefik.yml --profile backup run --rm sonarqube-backup --now
#
# Leave COMPOSE_PROFILES empty (the default) to keep the sidecar disabled.
COMPOSE_PROFILES=

# Dumps the SonarQube PostgreSQL database (the only stateful component worth
# backing up — ES indexes and plugins are rebuildable). Optionally uploads the
# archive to an external S3 bucket and prunes old archives by count.
SONARQUBE_BACKUP_INSTANCE_NAME=sonarqube

# Schedule
SONARQUBE_BACKUP_SCHEDULE_ENABLED=true
SONARQUBE_BACKUP_SCHEDULE_MODE=cron          # cron | interval
SONARQUBE_BACKUP_SCHEDULE_CRON=15 3 * * *    # daily 03:15 (TIME_ZONE)
SONARQUBE_BACKUP_SCHEDULE_INTERVAL_HOURS=24  # used when MODE=interval
SONARQUBE_BACKUP_ON_STARTUP=false            # run one backup immediately on boot

# Dump
SONARQUBE_BACKUP_DUMP_FORMAT=custom          # custom (pg_restore) | plain (.sql.gz)
SONARQUBE_BACKUP_DUMP_TIMEOUT_SECONDS=1800
SONARQUBE_BACKUP_RETENTION_COUNT=14          # keep N newest archives
SONARQUBE_BACKUP_KEEP_LOCAL_ARCHIVE=true     # keep local copy after S3 upload

# Optional off-site target (leave endpoint empty for local-only backups)
SONARQUBE_BACKUP_S3_ENDPOINT=
SONARQUBE_BACKUP_S3_BUCKET=
SONARQUBE_BACKUP_S3_ACCESS_KEY=
SONARQUBE_BACKUP_S3_SECRET_KEY=
SONARQUBE_BACKUP_S3_REGION=eu-central-1
SONARQUBE_BACKUP_S3_PREFIX=sonarqube/
SONARQUBE_BACKUP_S3_MAX_WORKERS=4

# Alerting
SONARQUBE_BACKUP_ALERT_ENABLED=false
SONARQUBE_BACKUP_ALERT_LEVEL=warnings        # errors | warnings | all
SONARQUBE_BACKUP_ALERT_CHANNELS=             # comma list: email,webhook,teams
SONARQUBE_BACKUP_ALERT_EMAIL=                # recipient for the email channel
SONARQUBE_BACKUP_WEBHOOK_URL=
SONARQUBE_BACKUP_WEBHOOK_SECRET=
SONARQUBE_BACKUP_TEAMS_WEBHOOK=

# Logging
SONARQUBE_BACKUP_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
SONARQUBE_BACKUP_LOG_FORMAT=console          # console | json
