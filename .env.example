# =============================================================================
# SonarQube вҖ” BAUER GROUP Self-Hosted Stack вҖ” Environment Template
# =============================================================================
# Copy to `.env` and fill in the CHANGE_ME_* values, or generate one with:
#
#     python scripts/generate-env.py
#
# The generator fills POSTGRES_PASSWORD with a random hex secret. Everything
# else has a working default or is an operator-supplied integration value.
#
# Variable expansion: `${VAR}` references below are resolved by Docker Compose
# from THIS file when rendering the compose `environment:` blocks. Values are
# NOT expanded within this file itself вҖ” keep literal values literal.
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================
# STACK_NAME prefixes every container, volume and the internal network so
# multiple stacks can coexist on one host (e.g. sonarqube_APP, sonarqube-postgres).
STACK_NAME=sonarqube

# IANA timezone for all containers (log timestamps, scheduler, DB).
TIME_ZONE=Europe/Berlin


# =============================================================================
# Image Configuration
# =============================================================================
# --- Wrapper image (pulled by the traefik / coolify variants in production) ---
SONARQUBE_IMAGE=ghcr.io/bauer-group/XPD-SonarQube/sonarqube
SONARQUBE_VERSION=latest

# --- Build inputs (used by docker-compose.development.yml `build:` and CI) -----
# Bump these TWO as a PAIR вҖ” the branch plugin MAJOR.MINOR must equal the
# SonarQube MAJOR.MINOR, or SonarQube refuses to start. Confirm a matching pair
# exists before bumping:
#   SonarQube tags : https://hub.docker.com/_/sonarqube  (вҖҰ-community)
#   Plugin releases: https://github.com/mc1arke/sonarqube-community-branch-plugin/releases
# Do NOT use the floating `community`/`latest` SonarQube tag here вҖ” it races
# ahead of the plugin. See docs/upgrade.md.
SONARQUBE_BASE_VERSION=26.5.0.122743-community
BRANCH_PLUGIN_VERSION=26.5.0

# --- PostgreSQL ---------------------------------------------------------------
# Plain postgres (NO pgvector вҖ” SonarQube needs no vector extension).
# Keep within SonarQube's supported PostgreSQL range; 16 is broadly compatible.
POSTGRES_IMAGE=postgres
POSTGRES_VERSION=16-alpine

# --- Kernel init sidecar (sets vm.max_map_count / fs.file-max for Elasticsearch)
SONARQUBE_INIT_IMAGE=busybox
SONARQUBE_INIT_VERSION=1.37

# --- Backup sidecar -----------------------------------------------------------
SONARQUBE_BACKUP_IMAGE=ghcr.io/bauer-group/XPD-SonarQube/sonarqube-backup
SONARQUBE_BACKUP_VERSION=latest


# =============================================================================
# Hostnames & Reverse Proxy (traefik / coolify variants only)
# =============================================================================
# Public FQDN. A DNS A/AAAA record must point at the reverse-proxy host BEFORE
# first start (Let's Encrypt HTTP-01 challenge needs it reachable).
SONARQUBE_HOSTNAME=sonarqube.development.app.bauer-group.com

# External Docker network your Traefik instance is attached to.
PROXY_NETWORK=EDGEPROXY


# =============================================================================
# SonarQube Application
# =============================================================================
# Host port for the development variant only (traefik/coolify expose via proxy).
SONARQUBE_PORT=9000

# Server base URL вҖ” used to build correct links in notifications and PR
# decoration. Leave EMPTY to use each compose variant's sensible default:
#   development вҶ’ http://localhost:${SONARQUBE_PORT}
#   traefik / coolify вҶ’ https://${SONARQUBE_HOSTNAME}
# Set it explicitly only to override (e.g. a custom domain or sub-path).
SONARQUBE_SERVER_BASE_URL=

# --- JVM heap sizing ----------------------------------------------------------
# SonarQube runs THREE JVMs. These are HEAP opts only вҖ” the branch-plugin
# -javaagent options are baked into the wrapper image (do not add them here).
#
#   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
#   в”Ӯ Host RAM budget     в”Ӯ 4 GB (def.)  в”Ӯ 8 GB         в”Ӯ 16 GB         в”Ӯ
#   в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
#   в”Ӯ WEB_JAVAOPTS  -Xmx  в”Ӯ 512m         в”Ӯ 1g           в”Ӯ 2g            в”Ӯ
#   в”Ӯ CE_JAVAOPTS   -Xmx  в”Ӯ 512m         в”Ӯ 1g           в”Ӯ 2g            в”Ӯ
#   в”Ӯ SEARCH (ES)   -Xmx  в”Ӯ 512m         в”Ӯ 1g           в”Ӯ 2g            в”Ӯ
#   в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
# Elasticsearch wants -Xms == -Xmx (no heap resize) and MaxDirectMemorySize
# at ~half the heap.
SONAR_WEB_JAVAOPTS=-Xmx512m -Xms128m
SONAR_CE_JAVAOPTS=-Xmx512m -Xms128m
SONAR_SEARCH_JAVAOPTS=-Xmx512m -Xms512m -XX:MaxDirectMemorySize=256m


# =============================================================================
# PostgreSQL (SonarQube database)
# =============================================================================
POSTGRES_USER=sonar
POSTGRES_DB=sonar
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# --- Performance tuning (baseline: 4 GB host, SSD/NVMe) -----------------------
#   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
#   в”Ӯ Setting                   в”Ӯ 4 GB     в”Ӯ 8 GB     в”Ӯ 16 GB    в”Ӯ
#   в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
#   в”Ӯ PG_SHARED_BUFFERS         в”Ӯ 512MB    в”Ӯ 2GB      в”Ӯ 4GB      в”Ӯ
#   в”Ӯ PG_EFFECTIVE_CACHE_SIZE   в”Ӯ 1536MB   в”Ӯ 6GB      в”Ӯ 12GB     в”Ӯ
#   в”Ӯ PG_WORK_MEM               в”Ӯ 8MB      в”Ӯ 16MB     в”Ӯ 32MB     в”Ӯ
#   в”Ӯ PG_MAINTENANCE_WORK_MEM   в”Ӯ 128MB    в”Ӯ 256MB    в”Ӯ 512MB    в”Ӯ
#   в”Ӯ PG_MAX_WAL_SIZE           в”Ӯ 1GB      в”Ӯ 2GB      в”Ӯ 4GB      в”Ӯ
#   в”Ӯ PG_MIN_WAL_SIZE           в”Ӯ 256MB    в”Ӯ 512MB    в”Ӯ 1GB      в”Ӯ
#   в”Ӯ PG_MAX_CONNECTIONS        в”Ӯ 100      в”Ӯ 150      в”Ӯ 200      в”Ӯ
#   в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
PG_MAX_CONNECTIONS=100
PG_SHARED_BUFFERS=512MB
PG_WORK_MEM=8MB
PG_EFFECTIVE_CACHE_SIZE=1536MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_MAX_WAL_SIZE=1GB
PG_MIN_WAL_SIZE=256MB
PG_RANDOM_PAGE_COST=1.1
PG_EFFECTIVE_IO_CONCURRENCY=200


# =============================================================================
# SMTP
# =============================================================================
# Used by the BACKUP sidecar for e-mail alerts (reliable, env-driven).
#
# NOTE: SonarQube's OWN notification e-mails are configured in the web UI under
# Administration вҶ’ Configuration вҶ’ General вҶ’ Email (stored in the database), not
# via these variables. See docs/installation.md.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_SECURE=starttls


# =============================================================================
# Backup Sidecar (profile: backup)
# =============================================================================
# Enable with:  docker compose -f docker-compose.traefik.yml --profile backup up -d
# Run on demand: docker compose -f docker-compose.traefik.yml --profile backup run --rm sonarqube-backup --now
#
# Dumps the SonarQube PostgreSQL database (the only stateful component worth
# backing up вҖ” ES indexes and plugins are rebuildable). Optionally uploads the
# archive to an external S3 bucket and prunes old archives by count.
SONARQUBE_BACKUP_INSTANCE_NAME=sonarqube

# Schedule
SONARQUBE_BACKUP_SCHEDULE_ENABLED=true
SONARQUBE_BACKUP_SCHEDULE_MODE=cron          # cron | interval
SONARQUBE_BACKUP_SCHEDULE_CRON=15 3 * * *    # daily 03:15 (TIME_ZONE)
SONARQUBE_BACKUP_SCHEDULE_INTERVAL_HOURS=24  # used when MODE=interval
SONARQUBE_BACKUP_ON_STARTUP=false            # run one backup immediately on boot

# Dump
SONARQUBE_BACKUP_DUMP_FORMAT=custom          # custom (pg_restore) | plain (.sql.gz)
SONARQUBE_BACKUP_DUMP_TIMEOUT_SECONDS=1800
SONARQUBE_BACKUP_RETENTION_COUNT=14          # keep N newest archives
SONARQUBE_BACKUP_KEEP_LOCAL_ARCHIVE=true     # keep local copy after S3 upload

# Optional off-site target (leave endpoint empty for local-only backups)
SONARQUBE_BACKUP_S3_ENDPOINT=
SONARQUBE_BACKUP_S3_BUCKET=
SONARQUBE_BACKUP_S3_ACCESS_KEY=
SONARQUBE_BACKUP_S3_SECRET_KEY=
SONARQUBE_BACKUP_S3_REGION=eu-central-1
SONARQUBE_BACKUP_S3_PREFIX=sonarqube/
SONARQUBE_BACKUP_S3_MAX_WORKERS=4

# Alerting
SONARQUBE_BACKUP_ALERT_ENABLED=false
SONARQUBE_BACKUP_ALERT_LEVEL=warnings        # errors | warnings | all
SONARQUBE_BACKUP_ALERT_CHANNELS=             # comma list: email,webhook,teams
SONARQUBE_BACKUP_ALERT_EMAIL=                # recipient for the email channel
SONARQUBE_BACKUP_WEBHOOK_URL=
SONARQUBE_BACKUP_WEBHOOK_SECRET=
SONARQUBE_BACKUP_TEAMS_WEBHOOK=

# Logging
SONARQUBE_BACKUP_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
SONARQUBE_BACKUP_LOG_FORMAT=console          # console | json
